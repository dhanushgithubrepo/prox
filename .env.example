# FastAPI + Gradio (single service)
GEMINI_API_KEY=
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
LANGSMITH_API_KEY=
REDIS_URL=redis://default:password@your-redis-host:6379
ALLOWED_ORIGINS=*

# Gradio calls the API on the same host (set only if running UI separately)
API_URL=http://127.0.0.1:8000
